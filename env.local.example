# ============================================
# Supabase
# Project Settings > API Keys から取得
# ============================================

# Project URL
# 画面上部の「Project URL」または Settings > General から確認
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable key（画面: "Publishable key" > default の API KEY）
# sb_publishable_... で始まるキー
# ブラウザに公開してOK（RLSで保護されている）
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key（画面: "Secret keys" > default の API KEY）
# sb_secret_... で始まるキー（目のアイコンで表示）
# 絶対に公開しないこと。サーバーサイドのみで使用
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Revalidate
# ============================================

# ISR（ページ再生成）用のシークレット
# 任意の文字列を自分で決めて設定する（例: openssl rand -hex 32 で生成）
REVALIDATE_SECRET=your-random-secret-string
